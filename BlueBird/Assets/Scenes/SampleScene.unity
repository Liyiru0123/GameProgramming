--- !u!114 &1290008400
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1290008395}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f944806bc10d40148af2908fb6c2749e, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  speakerName: Him
  dialogueLines:
  - I know you can get here, you never let me down.
  - You probably do not remember me.
  - 'That is fine.

'
  - 'I made sure you would not.

'
  - You once searched for the truth.
  - That truth killed you.
  - I could not save your life.
  - So I saved what was left of you.
  - I placed you in this body.
  - I watched you walk through the snow.
  - I watched you die, return, and continue.
  - I was never in those rooms.
  - But I was seeing you......
  - If you want freedom, take the core from my heart.
  - This is the last thing I can give you.
  - 'Leave this mountain.

'
  - Live without me.
  triggerOnlyOnce: 1
